---
import '../styles/global.css';
import RedeSwitcher from '../components/RedeSwitcher.astro';
import Preloader from '../components/Preloader.astro';

interface Props {
  title: string;
  description: string;
  redeAtual?: string;
}
const { title, description, redeAtual } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- tipografia do tema sonaar.io/demos/?theme=Promote (referencia que Tore pediu
         pra copiar): Poppins nos titulos/display, Lato no corpo, Abel nos labels
         maiusculos do menu -->
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Poppins:wght@300;400;500;600;700;800&family=Lato:wght@400;700&family=Abel&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-black text-paper font-body antialiased">
    <Preloader />
    <div id="site-nav-wrap" class="nav-overlay-gradient fixed inset-x-0 top-0 z-50">
      {redeAtual && <RedeSwitcher atual={redeAtual} />}
      <slot name="nav" />
    </div>
    <slot />

    <script>
      // depois do hero, o degrade transparente vira fundo preto solido pra
      // nao brigar com o conteudo das secoes normais (Tore reportou "atrapalhar
      // a leitura do menu" quando o fundo continuava so transparente)
      const navWrap = document.getElementById('site-nav-wrap');
      if (navWrap) {
        const onScroll = () => {
          navWrap.classList.toggle('nav-solid', window.scrollY > 80);
        };
        onScroll();
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>
