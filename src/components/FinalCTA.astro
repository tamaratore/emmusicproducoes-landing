---
import { WHATSAPP } from '../data/site';
import SoundWave from './SoundWave.astro';
---

<section class="relative overflow-hidden py-28 sm:py-36" data-final-cta>
  <div class="pointer-events-none absolute inset-x-0 bottom-0 opacity-30" aria-hidden="true">
    <SoundWave seed="final-cta" strokeWidth={3} class="h-40 w-full" />
  </div>
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-signal-purple/10 via-transparent to-transparent" aria-hidden="true"></div>

  <div class="container-editorial relative flex flex-col items-center text-center">
    <h2
      class="max-w-3xl font-display text-[clamp(2.25rem,7vw,4.75rem)] uppercase leading-[0.95] text-paper text-balance"
      data-reveal
    >
      A sua próxima música<br />
      <span class="text-gradient-signal">pode começar agora.</span>
    </h2>
    <p class="mt-6 max-w-md text-mist" data-reveal>
      Conte sua ideia e descubra o próximo passo para o seu projeto.
    </p>
    <a
      href={WHATSAPP.geral}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-primary mt-9"
      data-reveal
      data-magnetic
    >
      Falar com a EM Music<span class="sr-only"> (abre no WhatsApp em nova aba)</span>
    </a>
  </div>
</section>
