---
import { SERVICES, WHATSAPP } from '../data/site';
import SoundWave from './SoundWave.astro';
---

<section id="servicos" class="relative overflow-hidden bg-void-raised py-24 sm:py-32">
  <!-- vinheta de estúdio: luz de spot no canto + textura de grão, sem imagem de banco -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute -top-1/3 right-0 h-[70vh] w-[70vh] rounded-full bg-signal-magenta/10 blur-[120px]"></div>
    <div class="absolute inset-0 opacity-[0.06] [background-image:radial-gradient(circle,_#F2EFEA_1px,_transparent_1px)] [background-size:3px_3px]"></div>
  </div>

  <div class="container-editorial relative">
    <p class="eyebrow" data-reveal>Produção musical</p>
    <h2 class="mt-3 max-w-2xl font-display text-[clamp(2.25rem,6vw,4rem)] uppercase leading-[1.05] tracking-[0.01em] text-paper" data-reveal>
      Da ideia à música pronta
    </h2>
    <p class="mt-5 max-w-xl text-mist" data-reveal>
      Produção e acompanhamento em estúdio para transformar uma ideia musical em um projeto pronto
      para seguir adiante — como uma trilha sendo montada, faixa por faixa.
    </p>
  </div>

  <div class="relative mt-16 lg:overflow-hidden" data-services-pin>
    <!-- trilho de "claquete": numeração em estilo timecode + linha contínua, como uma
         edição de vídeo — reforça o lado audiovisual do trabalho, não só áudio -->
    <div
      class="container-editorial flex flex-col gap-0 lg:w-max lg:flex-row lg:gap-0"
      data-services-track
    >
      {
        SERVICES.map((service, i) => (
          <div class="group relative flex items-center gap-6 border-t border-mist/15 py-6 transition-colors lg:h-[48vh] lg:w-[20rem] lg:flex-col lg:items-start lg:justify-between lg:border-t-0 lg:border-l lg:border-r-0 lg:py-10 lg:pl-8 lg:first:border-l-0">
            <span
              class="pointer-events-none absolute inset-x-0 top-0 hidden h-[2px] scale-x-0 bg-gradient-to-r from-signal-purple via-signal-magenta to-signal-pink transition-transform duration-500 [transform-origin:left] group-hover:scale-x-100 lg:block"
              aria-hidden="true"
            />
            <span class="font-display text-lg tabular-nums text-signal-pink lg:text-xl">
              {String(i + 1).padStart(2, '0')}<span class="text-mist/40">/{String(SERVICES.length).padStart(2, '0')}</span>
            </span>
            <span class="flex-1 font-display text-2xl uppercase leading-[1.05] tracking-[0.01em] text-paper lg:mt-4 lg:text-3xl">
              {service}
            </span>
            <SoundWave seed={`service-${i}`} variant="bars" bars={14} class="hidden h-10 w-full lg:flex" />
          </div>
        ))
      }
    </div>
  </div>

  <div class="container-editorial relative mt-16 flex flex-col items-start gap-4" data-reveal>
    <p class="max-w-md text-sm text-mist">
      Sem prazos ou pacotes fechados prometidos aqui — cada projeto é conversado com a EM Music
      antes de começar.
    </p>
    <a href={WHATSAPP.projeto} target="_blank" rel="noopener noreferrer" class="btn-primary" data-magnetic>
      Falar sobre meu projeto<span class="sr-only"> (abre no WhatsApp em nova aba)</span>
    </a>
  </div>
</section>
