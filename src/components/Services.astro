---
import { SERVICES, WHATSAPP } from '../data/site';
---

<section id="servicos" class="relative overflow-hidden bg-void-raised py-20 sm:py-28">
  <div class="container-editorial relative flex flex-col items-center text-center">
    <p class="eyebrow" data-reveal>Produção musical</p>
    <h2 class="mt-3 max-w-xl font-display text-[clamp(2rem,5.5vw,3.25rem)] uppercase leading-[1.1] tracking-[0.01em] text-paper" data-reveal>
      Da ideia à música pronta
    </h2>
    <p class="mt-5 max-w-lg text-mist" data-reveal>
      Tudo o que a gente faz pra transformar sua ideia em uma música pronta pra tocar.
    </p>

    <div class="mt-12 flex max-w-3xl flex-wrap justify-center gap-3" data-reveal>
      {
        SERVICES.map((service) => (
          <span class="rounded-full border border-mist/25 px-5 py-2.5 font-body text-sm font-semibold uppercase tracking-wide text-paper/90">
            {service}
          </span>
        ))
      }
    </div>

    <p class="mt-10 max-w-md text-sm text-mist" data-reveal>
      Sem prazos ou pacotes fechados prometidos aqui — cada projeto é conversado com você antes de
      começar.
    </p>
    <a href={WHATSAPP.projeto} target="_blank" rel="noopener noreferrer" class="btn-primary mt-5" data-magnetic>
      Falar sobre meu projeto<span class="sr-only"> (abre no WhatsApp em nova aba)</span>
    </a>
  </div>
</section>
