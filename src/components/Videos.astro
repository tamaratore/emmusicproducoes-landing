---
import { VIDEOS, SOCIAL } from '../data/site';
---

<section id="videos" class="relative overflow-hidden py-24 sm:py-32">
  <div class="pointer-events-none absolute inset-0 opacity-[0.35]" aria-hidden="true">
    <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-signal-purple/0 via-signal-magenta/50 to-signal-pink/0"></div>
  </div>

  <div class="container-editorial">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow" data-reveal>No palco e nos bastidores</p>
        <h2 class="mt-3 max-w-2xl font-display text-[clamp(2.25rem,6vw,4rem)] uppercase leading-[1.05] tracking-[0.01em] text-paper" data-reveal>
          Clipes e produções reais
        </h2>
        <p class="mt-5 max-w-xl text-mist" data-reveal>
          Trabalhos assinados por Eder Machado e pela EM Music — direto dos canais oficiais, sem
          material de banco de imagens.
        </p>
      </div>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        VIDEOS.map((video, i) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex flex-col overflow-hidden rounded-sm border border-mist/15 bg-void-raised transition-colors hover:border-signal-pink/60"
            data-reveal
            style={`transition-delay:${(i % 3) * 60}ms`}
          >
            <span class="relative block aspect-video w-full overflow-hidden bg-void">
              <img
                src={video.thumbnail}
                alt={video.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void/80 via-void/0 to-void/0" />
              <span
                class="absolute inset-0 flex items-center justify-center opacity-90 transition-opacity group-hover:opacity-100"
                aria-hidden="true"
              >
                <span class="flex h-12 w-12 items-center justify-center rounded-full bg-void/70 ring-1 ring-paper/40 backdrop-blur-sm transition-transform group-hover:scale-110">
                  <svg viewBox="0 0 24 24" class="ml-0.5 h-5 w-5 fill-paper">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </span>
            </span>
            <span class="flex flex-1 flex-col gap-2 p-5">
              <span class="eyebrow !text-signal-pink">{video.channelLabel}</span>
              <span class="font-display text-base uppercase leading-[1.15] text-paper sm:text-lg">
                {video.title}
              </span>
              <span class="sr-only"> (abre no YouTube em nova aba)</span>
            </span>
          </a>
        ))
      }
    </div>

    <div class="mt-14 flex flex-wrap items-center gap-x-8 gap-y-4" data-reveal>
      <span class="eyebrow !text-mist/60">Canais oficiais</span>
      {
        SOCIAL.youtube.map((channel) => (
          <a
            href={channel.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-1.5 text-sm font-semibold uppercase tracking-wide text-paper/80 transition-colors hover:text-signal-pink"
          >
            {channel.label}
            <span class="sr-only"> (abre no YouTube em nova aba)</span>
            <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
