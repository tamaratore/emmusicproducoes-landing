---
import { VIDEOS, SOCIAL } from '../data/site';

// o vídeo [0] já aparece em destaque no topo do site — aqui mostramos só mais alguns
const rest = VIDEOS.slice(1, 4);
---

<section id="videos" class="relative py-20 sm:py-28">
  <div class="container-editorial flex flex-col items-center text-center">
    <p class="eyebrow" data-reveal>Mais exemplos</p>
    <h2 class="mt-3 max-w-xl font-display text-[clamp(2rem,5.5vw,3.25rem)] uppercase leading-[1.1] tracking-[0.01em] text-paper" data-reveal>
      Clipes e produções reais
    </h2>

    <div class="mt-12 grid w-full gap-6 sm:grid-cols-3">
      {
        rest.map((video) => (
          <a
            href={video.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block overflow-hidden rounded-lg border border-mist/15 bg-void-raised"
            data-reveal
          >
            <span class="relative block aspect-video w-full overflow-hidden">
              <img
                src={video.thumbnail}
                alt={video.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void/80 via-void/10 to-void/0" />
              <span class="absolute inset-0 flex items-center justify-center">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-void/70 ring-1 ring-paper/40 transition-transform group-hover:scale-110">
                  <svg viewBox="0 0 24 24" class="ml-0.5 h-4 w-4 fill-paper">
                    <path d="M8 5v14l11-7z" />
                  </svg>
                </span>
              </span>
              <span class="absolute bottom-0 inset-x-0 p-3 text-left">
                <span class="font-display text-sm uppercase leading-tight text-paper">{video.title}</span>
              </span>
            </span>
            <span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
        ))
      }
    </div>

    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-8 gap-y-3" data-reveal>
      {
        SOCIAL.youtube.map((channel) => (
          <a
            href={channel.url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold uppercase tracking-wide text-paper/80 transition-colors hover:text-signal-pink"
          >
            {channel.label}
            <span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
