---
interface Props {
  whatsappUrl: string;
}
const { whatsappUrl } = Astro.props;

const LINKS = [
  { href: '#topo', label: 'Início' },
  { href: '#em-music', label: 'O que fazemos' },
  { href: '#lancamentos', label: 'Lançamentos' },
  { href: '#videos', label: 'Clipe' },
];

// so 1 Instagram aqui no menu (EM Music) pra nao duplicar icone - o
// Instagram/YouTube do Eder Machado (gospel) fica detalhado la embaixo em
// "Ver mais", onde da pra distinguir cada marca por nome
const SOCIALS = [
  { name: 'YouTube EM Music', href: 'https://www.youtube.com/@emproducoesofficial6670' },
  { name: 'Instagram EM Music', href: 'https://www.instagram.com/emmusicproducoes/' },
  { name: 'Facebook', href: 'https://www.facebook.com/prodedermachado/' },
];
---
<div id="site-nav" class="hidden sm:block">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3 sm:px-6">
    <a href="#topo" class="flex shrink-0 items-center">
      <img
        src="/images/em-music-logo.png"
        alt="EM Music Produções / Prod. Eder Machado"
        class="h-8 w-auto sm:h-9"
        width="1400"
        height="586"
      />
    </a>

    <nav class="hidden items-center gap-6 md:flex">
      {LINKS.map((l) => (
        <a
          href={l.href}
          class="font-accent text-sm uppercase tracking-[0.15em] text-paper transition hover:text-brand-pink"
        >
          {l.label}
        </a>
      ))}
    </nav>

    <div class="hidden items-center gap-3 lg:flex">
      {SOCIALS.map((s) => (
        <a
          href={s.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={s.name}
          class="flex h-8 w-8 items-center justify-center text-paper/80 transition hover:text-brand-pink"
        >
          {s.name.startsWith('YouTube') && (
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M23 12s0-3.6-.46-5.3a2.9 2.9 0 0 0-2-2C18.9 4.2 12 4.2 12 4.2s-6.9 0-8.54.5a2.9 2.9 0 0 0-2 2C1 8.4 1 12 1 12s0 3.6.46 5.3a2.9 2.9 0 0 0 2 2c1.64.5 8.54.5 8.54.5s6.9 0 8.54-.5a2.9 2.9 0 0 0 2-2C23 15.6 23 12 23 12ZM9.75 15.5v-7l6 3.5Z"/></svg>
          )}
          {s.name.startsWith('Instagram') && (
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M12 2.2c3.2 0 3.6 0 4.9.07 1.2.06 2 .24 2.5.42.63.25 1.1.55 1.55 1a4.2 4.2 0 0 1 1 1.55c.18.5.36 1.3.42 2.5.07 1.3.07 1.7.07 4.9s0 3.6-.07 4.9c-.06 1.2-.24 2-.42 2.5-.25.63-.55 1.1-1 1.55a4.2 4.2 0 0 1-1.55 1c-.5.18-1.3.36-2.5.42-1.3.07-1.7.07-4.9.07s-3.6 0-4.9-.07c-1.2-.06-2-.24-2.5-.42a4.2 4.2 0 0 1-1.55-1 4.2 4.2 0 0 1-1-1.55c-.18-.5-.36-1.3-.42-2.5-.07-1.3-.07-1.7-.07-4.9s0-3.6.07-4.9c.06-1.2.24-2 .42-2.5.25-.63.55-1.1 1-1.55a4.2 4.2 0 0 1 1.55-1c.5-.18 1.3-.36 2.5-.42C8.4 2.2 8.8 2.2 12 2.2Zm0 1.8c-3.15 0-3.5 0-4.75.07-1 .05-1.6.2-1.94.34-.5.2-.84.42-1.2.8-.38.36-.6.7-.8 1.2-.14.34-.3.94-.34 1.94C2.9 9.5 2.9 9.85 2.9 13s0 3.5.07 4.75c.05 1 .2 1.6.34 1.94.2.5.42.84.8 1.2.36.38.7.6 1.2.8.34.14.94.3 1.94.34 1.25.07 1.6.07 4.75.07s3.5 0 4.75-.07c1-.05 1.6-.2 1.94-.34.5-.2.84-.42 1.2-.8.38-.36.6-.7.8-1.2.14-.34.3-.94.34-1.94.07-1.25.07-1.6.07-4.75s0-3.5-.07-4.75c-.05-1-.2-1.6-.34-1.94a3 3 0 0 0-.8-1.2 3 3 0 0 0-1.2-.8c-.34-.14-.94-.3-1.94-.34C15.5 4 15.15 4 12 4Zm0 3.3a5.7 5.7 0 1 1 0 11.4 5.7 5.7 0 0 1 0-11.4Zm0 1.8a3.9 3.9 0 1 0 0 7.8 3.9 3.9 0 0 0 0-7.8Zm5.9-2a1.3 1.3 0 1 1-2.6 0 1.3 1.3 0 0 1 2.6 0Z"/></svg>
          )}
          {s.name === 'Facebook' && (
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M14 22v-8.5h2.9l.4-3.3H14V8c0-.96.27-1.6 1.7-1.6H17.4V3.4A22 22 0 0 0 14.9 3.3c-2.5 0-4.2 1.5-4.2 4.4v2.5H8v3.3h2.7V22Z"/></svg>
          )}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="font-accent hidden rounded-full bg-gradient-to-r from-brand-purple to-brand-pink px-4 py-2 text-sm uppercase tracking-wide text-white sm:inline-block"
      >
        Falar com o Eder
      </a>
    </div>
  </div>
</div>
