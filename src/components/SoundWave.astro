---
// Onda sonora reutilizável — o elemento visual recorrente do "pulso cinematográfico".
// Gera um traçado orgânico (não um arquivo estático repetido) a partir de um seed
// determinístico, então cada instância no site tem uma silhueta levemente distinta
// sem depender de imagens externas.
//
// Uso típico:
//   <SoundWave seed="hero" />                     — linha decorativa estática/animada
//   <SoundWave seed="process" variant="progress" id="process-wave" /> — track de progresso
//   <SoundWave seed="eq" variant="bars" bars={32} /> — medidor tipo DAW

interface Props {
  seed?: string;
  variant?: 'line' | 'progress' | 'bars';
  bars?: number;
  strokeWidth?: number;
  class?: string;
  id?: string;
  animated?: boolean;
}

const {
  seed = 'default',
  variant = 'line',
  bars = 28,
  strokeWidth = 3,
  class: className = '',
  id,
  animated = true,
} = Astro.props;

// Hash simples e determinístico do seed, só pra variar a forma sem aleatoriedade real.
function hash(str: string): number {
  let h = 0;
  for (let i = 0; i < str.length; i++) {
    h = (h << 5) - h + str.charCodeAt(i);
    h |= 0;
  }
  return Math.abs(h);
}

const gradId = `wave-grad-${id ?? seed}`;
const seedNum = hash(seed);

function rand(offset: number): number {
  const x = Math.sin(seedNum + offset) * 10000;
  return x - Math.floor(x);
}

const width = 1000;
const height = 200;
const mid = height / 2;

function buildLinePath(): string {
  const points = 14;
  const coords: [number, number][] = [];
  for (let i = 0; i <= points; i++) {
    const x = (width / points) * i;
    const t = i / points;
    const envelope = Math.sin(t * Math.PI); // sobe e desce nas pontas
    const wobble = (rand(i * 3.1) - 0.5) * 2;
    const amp = 22 + rand(i * 1.7) * 46;
    const y = mid + Math.sin(t * Math.PI * (3 + rand(0) * 2) + seedNum) * amp * envelope + wobble * 6;
    coords.push([x, y]);
  }

  let d = `M ${coords[0][0]} ${coords[0][1]}`;
  for (let i = 0; i < coords.length - 1; i++) {
    const [x0, y0] = coords[i];
    const [x1, y1] = coords[i + 1];
    const cx = (x0 + x1) / 2;
    d += ` Q ${x0} ${y0} ${cx} ${(y0 + y1) / 2}`;
  }
  d += ` T ${coords[coords.length - 1][0]} ${coords[coords.length - 1][1]}`;
  return d;
}

const linePath = buildLinePath();

const barHeights = Array.from({ length: bars }, (_, i) => {
  const t = i / bars;
  const envelope = 0.35 + 0.65 * Math.sin(t * Math.PI);
  return Math.max(0.08, Math.min(1, (0.3 + rand(i * 2.3) * 0.7) * envelope));
});
---

{
  variant === 'bars' ? (
    <div
      class:list={['flex items-end gap-[3px]', className]}
      role="img"
      aria-label="Medidor de áudio, elemento decorativo"
      aria-hidden="true"
      data-wave-bars={animated ? '' : undefined}
    >
      {barHeights.map((h, i) => (
        <span
          class="w-[3px] rounded-sm bg-gradient-to-t from-signal-purple via-signal-magenta to-signal-pink"
          style={`height:${Math.round(h * 100)}%`}
          data-bar-index={i}
        />
      ))}
    </div>
  ) : (
    <svg
      viewBox={`0 0 ${width} ${height}`}
      preserveAspectRatio="none"
      class:list={['overflow-visible', className]}
      aria-hidden="true"
      data-wave={variant === 'progress' ? (id ?? seed) : undefined}
    >
      <defs>
        <linearGradient id={gradId} x1="0%" y1="0%" x2="100%" y2="0%">
          <stop offset="0%" stop-color="#7429A8" />
          <stop offset="55%" stop-color="#CB287D" />
          <stop offset="100%" stop-color="#EF3D9A" />
        </linearGradient>
      </defs>
      {variant === 'progress' && (
        <path
          d={linePath}
          fill="none"
          stroke="#2A2730"
          stroke-width={strokeWidth}
          stroke-linecap="round"
        />
      )}
      <path
        d={linePath}
        fill="none"
        stroke={`url(#${gradId})`}
        stroke-width={strokeWidth}
        stroke-linecap="round"
        pathLength="100"
        data-wave-path={variant === 'progress' ? 'progress' : animated ? 'draw' : undefined}
      />
    </svg>
  )
}
