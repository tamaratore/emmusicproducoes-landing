---
import { FOOTER_LINKS, WHATSAPP, SOCIAL } from '../data/site';
---

<footer class="border-t border-mist/10 bg-void py-16 pb-28 lg:pb-16">
  <div class="container-editorial">
    <div class="flex flex-col gap-12 lg:flex-row lg:justify-between">
      <div class="max-w-xs">
        <p class="font-display text-lg uppercase tracking-wide text-paper">EM Music Produções</p>
        <p class="mt-3 text-sm text-mist">emmusicproducoes.com.br</p>
        <a
          href={WHATSAPP.geral}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold uppercase tracking-wide text-signal-pink"
        >
          WhatsApp<span class="sr-only"> (abre em nova aba)</span>
          <span aria-hidden="true">→</span>
        </a>

        <div class="mt-6 flex items-center gap-3">
          <a
            href={SOCIAL.instagram[0].url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-mist/25 text-paper/70 transition-colors hover:border-signal-pink hover:text-signal-pink"
            aria-label="Instagram da EM Music (abre em nova aba)"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M12 2.2c3.2 0 3.58.01 4.85.07 1.17.05 1.97.24 2.43.4a4.9 4.9 0 0 1 1.77 1.15 4.9 4.9 0 0 1 1.15 1.77c.16.46.35 1.26.4 2.43.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.24 1.97-.4 2.43a4.9 4.9 0 0 1-1.15 1.77 4.9 4.9 0 0 1-1.77 1.15c-.46.16-1.26.35-2.43.4-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.97-.24-2.43-.4a4.9 4.9 0 0 1-1.77-1.15 4.9 4.9 0 0 1-1.15-1.77c-.16-.46-.35-1.26-.4-2.43C2.21 15.58 2.2 15.2 2.2 12s.01-3.58.07-4.85c.05-1.17.24-1.97.4-2.43A4.9 4.9 0 0 1 3.82 3a4.9 4.9 0 0 1 1.77-1.15c.46-.16 1.26-.35 2.43-.4C9.29 2.21 9.67 2.2 12 2.2Zm0 1.8c-3.15 0-3.5.01-4.73.07-.96.04-1.48.2-1.82.34-.46.18-.78.39-1.13.73-.34.35-.55.67-.73 1.13-.14.34-.3.86-.34 1.82-.06 1.23-.07 1.58-.07 4.73s.01 3.5.07 4.73c.04.96.2 1.48.34 1.82.18.46.39.78.73 1.13.35.34.67.55 1.13.73.34.14.86.3 1.82.34 1.23.06 1.58.07 4.73.07s3.5-.01 4.73-.07c.96-.04 1.48-.2 1.82-.34.46-.18.78-.39 1.13-.73.34-.35.55-.67.73-1.13.14-.34.3-.86.34-1.82.06-1.23.07-1.58.07-4.73s-.01-3.5-.07-4.73c-.04-.96-.2-1.48-.34-1.82a3.1 3.1 0 0 0-.73-1.13 3.1 3.1 0 0 0-1.13-.73c-.34-.14-.86-.3-1.82-.34-1.23-.06-1.58-.07-4.73-.07Zm0 3.5a5.5 5.5 0 1 1 0 11 5.5 5.5 0 0 1 0-11Zm0 1.8a3.7 3.7 0 1 0 0 7.4 3.7 3.7 0 0 0 0-7.4Zm5.72-1.99a1.29 1.29 0 1 1-2.58 0 1.29 1.29 0 0 1 2.58 0Z"/></svg>
          </a>
          <a
            href={SOCIAL.youtube[0].url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex h-9 w-9 items-center justify-center rounded-full border border-mist/25 text-paper/70 transition-colors hover:border-signal-pink hover:text-signal-pink"
            aria-label="YouTube da EM Music (abre em nova aba)"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4 fill-current"><path d="M21.58 7.19a2.75 2.75 0 0 0-1.94-1.95C17.9 4.75 12 4.75 12 4.75s-5.9 0-7.64.49a2.75 2.75 0 0 0-1.94 1.95C2 8.94 2 12 2 12s0 3.06.42 4.81a2.75 2.75 0 0 0 1.94 1.95c1.74.49 7.64.49 7.64.49s5.9 0 7.64-.49a2.75 2.75 0 0 0 1.94-1.95C22 15.06 22 12 22 12s0-3.06-.42-4.81ZM10 15.02V8.98L15.5 12 10 15.02Z"/></svg>
          </a>
        </div>
      </div>

      <nav aria-label="Links do rodapé" class="grid grid-cols-2 gap-x-10 gap-y-10 sm:grid-cols-3">
        {
          FOOTER_LINKS.columns.map((col) => (
            <div>
              <p class="eyebrow !text-mist/50">{col.heading}</p>
              <ul class="mt-4 flex flex-col gap-2.5">
                {col.links.map((link) =>
                  link.href ? (
                    <li>
                      <a
                        href={link.href}
                        target={'external' in link && link.external ? '_blank' : undefined}
                        rel={'external' in link && link.external ? 'noopener noreferrer' : undefined}
                        class="text-sm text-paper/75 transition-colors hover:text-paper"
                      >
                        {link.label}
                        {'external' in link && link.external && <span class="sr-only"> (abre em nova aba)</span>}
                      </a>
                    </li>
                  ) : (
                    <li>
                      <span class="text-sm text-mist/50">{link.label}</span>
                    </li>
                  ),
                )}
              </ul>
            </div>
          ))
        }
      </nav>
    </div>

    <div class="hairline mt-14"></div>
    <p class="mt-6 text-xs text-mist/50">
      EM Music Produções · parte do ecossistema Rede Loops Brasil.
    </p>
  </div>
</footer>
