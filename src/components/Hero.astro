---
import { WHATSAPP, EXTERNAL_LINKS, VIDEOS } from '../data/site';
import { publicFileExists } from '../utils/assets';

const logoExists = publicFileExists('images/brands/em-music.png');
const featured = VIDEOS[0];
---

<section id="topo" class="relative flex min-h-[100svh] flex-col items-center justify-center overflow-hidden pt-[--header-h] pb-16" style="--header-h: 4.5rem;">
  <!-- fundo simples: só um brilho suave, sem grid/onda abstrata competindo com o vídeo -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute left-1/2 top-1/3 h-[60vh] w-[60vh] -translate-x-1/2 -translate-y-1/2 rounded-full bg-signal-magenta/10 blur-[140px]"></div>
  </div>

  <div class="container-editorial relative flex flex-col items-center text-center">
    {
      logoExists ? (
        <img
          src="/images/brands/em-music.png"
          alt="EM Music Produções"
          class="h-16 w-auto sm:h-20"
          width="1400"
          height="586"
          data-reveal
        />
      ) : (
        <p class="font-display text-3xl uppercase tracking-wide text-paper">
          EM <span class="text-gradient-signal">MUSIC</span>
        </p>
      )
    }

    <h1
      class="mt-8 max-w-2xl font-display text-[clamp(2rem,5.5vw,3.25rem)] uppercase leading-[1.1] tracking-[0.01em] text-paper text-balance"
      data-reveal
    >
      Produção musical e distribuição para as plataformas digitais
    </h1>

    <p class="mt-5 max-w-lg text-base text-mist sm:text-lg" data-reveal>
      Você manda sua ideia, a gente produz, grava o clipe e coloca sua música no Spotify e no
      YouTube.
    </p>

    <!-- vídeo em destaque: um só, grande, centralizado, com efeito de brilho pulsante -->
    <a
      href={featured.url}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative mt-10 w-full max-w-2xl"
      data-reveal
    >
      <span class="video-glow pointer-events-none absolute -inset-3 rounded-2xl opacity-70 blur-2xl" aria-hidden="true"></span>
      <span class="relative flex aspect-video w-full items-center justify-center overflow-hidden rounded-lg border border-paper/15 bg-void-raised shadow-2xl">
        <img
          src={featured.thumbnail}
          alt={featured.title}
          class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
        />
        <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-void/70 via-void/0 to-void/0" />
        <span class="play-pulse absolute flex h-20 w-20 items-center justify-center rounded-full bg-void/60 ring-2 ring-paper/50 backdrop-blur-sm transition-transform group-hover:scale-110 sm:h-24 sm:w-24">
          <svg viewBox="0 0 24 24" class="ml-1 h-9 w-9 fill-paper sm:h-10 sm:w-10">
            <path d="M8 5v14l11-7z" />
          </svg>
        </span>
        <span class="absolute bottom-0 inset-x-0 p-4 text-left">
          <span class="font-display text-sm uppercase leading-tight text-paper sm:text-base">{featured.title}</span>
          <span class="mt-0.5 block text-xs text-mist">{featured.channelLabel} · assista no YouTube</span>
        </span>
      </span>
      <span class="sr-only"> (abre no YouTube em nova aba)</span>
    </a>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:justify-center" data-reveal>
      <a href={WHATSAPP.producao} target="_blank" rel="noopener noreferrer" class="btn-primary" data-magnetic>
        Produzir minha música<span class="sr-only"> (abre no WhatsApp em nova aba)</span>
      </a>
      <a href={EXTERNAL_LINKS.edTutoriais} target="_blank" rel="noopener noreferrer" class="btn-outline" data-magnetic>
        Comprar loops e instrumentos<span class="sr-only"> (abre em nova aba)</span>
      </a>
    </div>
  </div>
</section>

<style>
  .video-glow {
    background: linear-gradient(90deg, #7429a8, #cb287d, #ef3d9a);
    animation: video-glow-pulse 3.5s ease-in-out infinite;
  }
  @keyframes video-glow-pulse {
    0%,
    100% {
      opacity: 0.45;
    }
    50% {
      opacity: 0.8;
    }
  }
  .play-pulse::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 9999px;
    border: 1px solid rgba(242, 239, 234, 0.4);
    animation: play-pulse-ring 2.2s ease-out infinite;
  }
  @keyframes play-pulse-ring {
    0% {
      transform: scale(0.9);
      opacity: 0.8;
    }
    100% {
      transform: scale(1.35);
      opacity: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .video-glow,
    .play-pulse::before {
      animation: none;
    }
  }
</style>
