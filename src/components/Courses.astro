---
import { COURSE_PATHS, EXTERNAL_LINKS } from '../data/site';
---

<section id="cursos" class="relative bg-void-raised py-24 sm:py-32">
  <div class="container-editorial">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <p class="eyebrow" data-reveal>Quero aprender</p>
        <h2 class="mt-3 max-w-2xl font-display text-[clamp(2.25rem,6vw,4rem)] uppercase leading-[0.95] text-paper" data-reveal>
          Aprenda produção musical na prática
        </h2>
        <p class="mt-5 max-w-xl text-mist" data-reveal>
          Conteúdos para quem está começando, músicos que produzem em casa e produtores que querem
          evoluir.
        </p>
      </div>

      <a
        href={EXTERNAL_LINKS.edTutoriaisCursos}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary shrink-0"
        data-reveal
        data-magnetic
      >
        Acessar todos os cursos<span class="sr-only"> (abre em nova aba)</span>
      </a>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-sm bg-mist/10 sm:grid-cols-2 lg:grid-cols-5" data-reveal>
      {
        COURSE_PATHS.map((course, i) => (
          <a
            href={EXTERNAL_LINKS.edTutoriaisCursos}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex min-h-[13rem] flex-col justify-between bg-void-raised p-6 transition-colors hover:bg-void"
          >
            <span class="font-display text-sm text-signal-pink">{String(i + 1).padStart(2, '0')}</span>
            <span class="font-display text-xl uppercase leading-[1.05] text-paper transition-colors">
              {course.title}
            </span>
            <span
              aria-hidden="true"
              class="mt-4 inline-block w-fit text-mist/60 transition-all group-hover:translate-x-1 group-hover:text-signal-pink"
            >
              →
            </span>
            <span class="sr-only"> (abre em nova aba)</span>
          </a>
        ))
      }
    </div>
  </div>
</section>
