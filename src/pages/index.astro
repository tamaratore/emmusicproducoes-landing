---
import Base from '../layouts/Base.astro';

const WHATSAPP_NUMBER = '556296655336'; // +55 62 9665-5336, confirmado por Toré
const WHATSAPP_TEXT = encodeURIComponent('Vim pelo adesivo do carro! Quero falar sobre música.');
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_TEXT}`;

const paths = [
  {
    title: 'Grava com a gente',
    body: 'Presencial no estúdio ou remoto — grava em casa e manda os arquivos, sem precisar se deslocar.',
    cta: 'Falar no WhatsApp',
    href: WHATSAPP_URL,
    accent: 'brand-pink',
  },
  {
    title: 'Loop pronto na mão',
    body: 'Wave pra arrastar direto na tua DAW ou pacote Kontakt — pega o instrumental e já começa.',
    cta: 'Ver na Samples Brasil',
    href: 'https://samplesbrasil.com',
    accent: 'brand-purple',
  },
  {
    title: 'Aprende a produzir',
    body: 'Curso de produção musical direto com quem já produz há anos, sem enrolação.',
    cta: 'Ver cursos ED Tutoriais',
    href: 'https://edtutoriais.com.br',
    accent: 'brand-pink',
  },
  {
    title: 'Consultoria com o Eder',
    body: 'Travou numa mixagem ou não sabe por onde começar? Fala direto com ele.',
    cta: 'Chamar no WhatsApp',
    href: WHATSAPP_URL,
    accent: 'brand-purple',
  },
];

// vídeos reais dos 2 canais de produção (confirmados 17/07) — nunca thumbnail de banco
const videos = [
  {
    title: 'Adriano Lima — A Casa É Nossa',
    thumb: 'https://i.ytimg.com/vi/sBPhjQT0CIw/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=sBPhjQT0CIw',
  },
  {
    title: 'CD Sky Love ao vivo em Teresina',
    thumb: 'https://i.ytimg.com/vi/dUQutym_CfM/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=dUQutym_CfM',
  },
  {
    title: 'Yahweh — Júlia Fernandes',
    thumb: 'https://i.ytimg.com/vi/Gbb0YlkDSLk/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=Gbb0YlkDSLk',
  },
  {
    title: 'Rafaela — Adriano Lima',
    thumb: 'https://i.ytimg.com/vi/xNcooYAr_r0/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=xNcooYAr_r0',
  },
  {
    title: 'Adriano Lima — Estou Perdido',
    thumb: 'https://i.ytimg.com/vi/aM3a5Oue0QE/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=aM3a5Oue0QE',
  },
  {
    title: 'Desperta-me — Eder Machado feat. Júlia Fernandes',
    thumb: 'https://i.ytimg.com/vi/t42Vel5o7f8/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=t42Vel5o7f8',
  },
  {
    title: 'Os Xonados do Forró em Baixa Grande',
    thumb: 'https://i.ytimg.com/vi/-e279JoZv7Y/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=-e279JoZv7Y',
  },
  {
    title: 'Confia — Eder Machado',
    thumb: 'https://i.ytimg.com/vi/UBXXoSdAzKo/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=UBXXoSdAzKo',
  },
];
---
<Base
  title="EM Music Produções — Prod. Eder Machado"
  description="Grave, masterize, aprenda produção musical ou pegue loops prontos. Fale direto com o Eder Machado."
>
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden px-6 pt-16 pb-14 sm:pt-24 sm:pb-20">
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-purple/20 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-xl text-center">
        <img
          src="/images/em-music-logo.png"
          alt="EM Music Produções"
          class="mx-auto h-14 w-auto sm:h-16"
          width="1400"
          height="586"
        />

        <div class="mx-auto mt-6 flex h-10 items-end justify-center gap-1" aria-hidden="true">
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
          <span class="eq-bar w-1.5 rounded-full bg-gradient-to-t from-brand-purple to-brand-pink"></span>
        </div>

        <p class="mt-6 font-body text-sm font-semibold uppercase tracking-[0.2em] text-brand-pink">
          Chegou pelo adesivo do carro?
        </p>
        <h1 class="balance mt-4 font-display text-5xl leading-[0.95] text-paper sm:text-6xl">
          BORA FAZER MÚSICA DE VERDADE
        </h1>
        <p class="mt-5 text-lg text-paper/70">
          Grava, masteriza, aprende ou compra loop pronto — escolhe o caminho aí embaixo.
        </p>

        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-7 inline-flex items-center gap-2.5 rounded-full bg-gradient-to-r from-brand-purple to-brand-pink px-8 py-4 font-display text-lg uppercase tracking-wide text-paper transition-transform hover:scale-105"
        >
          <svg viewBox="0 0 24 24" class="h-5 w-5 fill-paper"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.4-.7-1.7-.8s-.4-.1-.6.1-.7.8-.9 1-.3.2-.6 0a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5s.2-.3.4-.4a1.6 1.6 0 0 0 .2-.4.5.5 0 0 0 0-.4c0-.1-.6-1.5-.8-2s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.2 5.1 5.1 0 0 0 1.1 2.7 11.6 11.6 0 0 0 4.4 3.9c.6.3 1.1.4 1.5.5a3.6 3.6 0 0 0 1.6.1 2.7 2.7 0 0 0 1.8-1.2 2.1 2.1 0 0 0 .1-1.2c-.1-.1-.2-.2-.5-.3Z"/></svg>
          Falar com o Eder agora
        </a>
        <p class="mt-2 text-xs text-paper/40">Responde rápido, sem enrolação.</p>
      </div>
    </section>

    <!-- FORK: os dois mundos -->
    <section class="px-6 pb-4">
      <div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-2">
        <a
          href="#em-music"
          class="reveal glow-card group rounded-2xl border border-ink-line bg-ink-raised p-6"
        >
          <p class="font-display text-2xl text-brand-pink">EM MUSIC PRODUÇÕES</p>
          <p class="mt-2 text-sm text-paper/60">
            Piseiro, arrocha, pagode, axé — o que toca na night.
          </p>
        </a>
        <a
          href="#prod-eder"
          class="reveal glow-card group rounded-2xl border border-ink-line bg-ink-raised p-6"
        >
          <p class="font-display text-2xl text-brand-purple">PROD. EDER MACHADO</p>
          <p class="mt-2 text-sm text-paper/60">
            Produção musical gospel, do jeito que edifica.
          </p>
        </a>
      </div>
    </section>

    <!-- OS 4 CAMINHOS -->
    <section id="em-music" class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">O que a gente faz por você</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {paths.map((p) => (
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="reveal glow-card flex flex-col rounded-2xl border border-ink-line bg-ink-raised p-6"
            >
              <span class={`text-xs font-semibold uppercase tracking-[0.15em] text-${p.accent}`}>
                {p.cta}
              </span>
              <h3 class="mt-3 font-display text-xl text-paper">{p.title}</h3>
              <p class="mt-2 text-sm text-paper/60">{p.body}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="prod-eder" class="sr-only" aria-hidden="true"></section>

    <!-- CLIPES REAIS -->
    <section class="py-14">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display text-3xl text-paper">Clipes e produções reais</h2>
        <p class="mt-2 text-sm text-paper/60">Direto dos nossos canais, sem imagem de banco.</p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {videos.map((v) => (
            <a
              href={v.url}
              target="_blank"
              rel="noopener noreferrer"
              class="glow-card group relative block overflow-hidden rounded-2xl border border-ink-line bg-ink-raised"
            >
              <span class="relative block aspect-video w-full overflow-hidden">
                <img
                  src={v.thumb}
                  alt={v.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
                <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/0 to-ink/0" />
                <span class="absolute inset-0 flex items-center justify-center">
                  <span class="flex h-11 w-11 items-center justify-center rounded-full bg-ink/70 ring-1 ring-paper/40">
                    <svg viewBox="0 0 24 24" class="ml-0.5 h-4 w-4 fill-paper"><path d="M8 5v14l11-7z" /></svg>
                  </span>
                </span>
              </span>
              <p class="p-4 text-sm font-semibold text-paper">{v.title}</p>
              <span class="sr-only"> (abre no YouTube em nova aba)</span>
            </a>
          ))}
        </div>

        <div class="mt-8 flex flex-wrap items-center gap-x-8 gap-y-3">
          <span class="text-sm text-paper/50">Ver mais:</span>
          <a
            href="https://www.youtube.com/@emproducooesofficial6670"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-brand-pink hover:text-paper"
          >
            Ir para EM Music Produções<span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
          <a
            href="https://www.youtube.com/@PRODERMACHADO"
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-semibold text-brand-purple hover:text-paper"
          >
            Ir para Prod. Eder Machado<span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
        </div>
      </div>
    </section>

    <!-- RODAPÉ -->
    <footer class="border-t border-ink-line px-6 py-10 pb-24 sm:pb-10">
      <div class="mx-auto flex max-w-4xl flex-col items-center gap-3 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-paper/40">Parte da</p>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-paper/60">
          <span>Rede Loops Brasil</span>
          <a href="https://edtutoriais.com.br" class="hover:text-paper">ED Tutoriais</a>
          <a href="https://samplesbrasil.com" class="hover:text-paper">Samples Brasil</a>
          <span>EDTMusic</span>
        </div>
      </div>
    </footer>
  </main>

  <!-- CONTATO RÁPIDO: sempre visível, um toque só, pra galera de chão não precisar procurar -->
  <a
    href={WHATSAPP_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="whatsapp-float fixed bottom-5 right-5 z-50 flex items-center gap-2 rounded-full bg-[#25D366] px-5 py-3.5 font-display text-base uppercase tracking-wide text-ink shadow-lg"
  >
    <svg viewBox="0 0 24 24" class="h-5 w-5 fill-ink"><path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.1-1.3A10 10 0 1 0 12 2Zm0 18.2a8.1 8.1 0 0 1-4.2-1.2l-.3-.2-3 .8.8-2.9-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.1c-.2-.1-1.4-.7-1.7-.8s-.4-.1-.6.1-.7.8-.9 1-.3.2-.6 0a6.7 6.7 0 0 1-2-1.2 7.4 7.4 0 0 1-1.4-1.7c-.1-.2 0-.4.1-.5s.2-.3.4-.4a1.6 1.6 0 0 0 .2-.4.5.5 0 0 0 0-.4c0-.1-.6-1.5-.8-2s-.4-.4-.6-.4h-.5a1 1 0 0 0-.7.3 2.9 2.9 0 0 0-.9 2.2 5.1 5.1 0 0 0 1.1 2.7 11.6 11.6 0 0 0 4.4 3.9c.6.3 1.1.4 1.5.5a3.6 3.6 0 0 0 1.6.1 2.7 2.7 0 0 0 1.8-1.2 2.1 2.1 0 0 0 .1-1.2c-.1-.1-.2-.2-.5-.3Z"/></svg>
    <span class="hidden sm:inline">Falar com o Eder</span>
    <span class="sr-only sm:hidden"> (abre no WhatsApp em nova aba)</span>
  </a>

  <script>
    import { gsap } from 'gsap';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll<HTMLElement>('.reveal');

    if (!prefersReduced && items.length) {
      gsap.set(items, { opacity: 0, y: 24 });
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              gsap.to(entry.target, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' });
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 },
      );
      items.forEach((el) => io.observe(el));
    }
  </script>
</Base>
