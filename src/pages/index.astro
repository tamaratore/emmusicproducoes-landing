---
import Base from '../layouts/Base.astro';

const WHATSAPP_NUMBER = '556296655336'; // +55 62 9665-5336, confirmado por Toré
const WHATSAPP_TEXT = encodeURIComponent('Vim pelo adesivo do carro! Quero falar sobre música.');
const WHATSAPP_URL = `https://wa.me/${WHATSAPP_NUMBER}?text=${WHATSAPP_TEXT}`;

const paths = [
  {
    title: 'Grava com a gente',
    body: 'Presencial no estúdio ou remoto — grava em casa e manda os arquivos, sem precisar se deslocar.',
    cta: 'Falar no WhatsApp',
    href: WHATSAPP_URL,
    accent: 'signal',
  },
  {
    title: 'Loop pronto na mão',
    body: 'Wave pra arrastar direto na tua DAW ou pacote Kontakt — pega o instrumental e já começa.',
    cta: 'Ver na Samples Brasil',
    href: 'https://samplesbrasil.com',
    accent: 'gospel',
  },
  {
    title: 'Aprende a produzir',
    body: 'Curso de produção musical direto com quem já produz há anos, sem enrolação.',
    cta: 'Ver cursos ED Tutoriais',
    href: 'https://edtutoriais.com.br',
    accent: 'signal',
  },
  {
    title: 'Consultoria com o Eder',
    body: 'Travou numa mixagem ou não sabe por onde começar? Fala direto com ele.',
    cta: 'Chamar no WhatsApp',
    href: WHATSAPP_URL,
    accent: 'gospel',
  },
];

// vídeos reais dos 3 canais oficiais (confirmados 17/07) — nunca thumbnail de banco
const videos = [
  {
    title: 'Adriano Lima — A Casa É Nossa',
    thumb: 'https://i.ytimg.com/vi/sBPhjQT0CIw/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=sBPhjQT0CIw',
  },
  {
    title: 'Desperta-me — Eder Machado feat. Júlia Fernandes',
    thumb: 'https://i.ytimg.com/vi/t42Vel5o7f8/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=t42Vel5o7f8',
  },
  {
    title: 'Rafaela — Adriano Lima',
    thumb: 'https://i.ytimg.com/vi/xNcooYAr_r0/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=xNcooYAr_r0',
  },
  {
    title: 'Yahweh — Júlia Fernandes',
    thumb: 'https://i.ytimg.com/vi/Gbb0YlkDSLk/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=Gbb0YlkDSLk',
  },
  {
    title: 'CD Sky Love ao vivo em Teresina',
    thumb: 'https://i.ytimg.com/vi/dUQutym_CfM/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=dUQutym_CfM',
  },
  {
    title: 'Como lançar pads pelo celular (app grátis)',
    thumb: 'https://i.ytimg.com/vi/Cx4iqoDWMLs/maxresdefault.jpg',
    url: 'https://www.youtube.com/watch?v=Cx4iqoDWMLs',
  },
];
---
<Base
  title="EM Music Produções — Prod. Eder Machado"
  description="Grave, masterize, aprenda produção musical ou pegue loops prontos. Fale direto com o Eder Machado."
>
  <main>
    <!-- HERO -->
    <section class="relative overflow-hidden px-6 pt-16 pb-14 sm:pt-24 sm:pb-20">
      <div
        class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-signal/20 blur-3xl"
        aria-hidden="true"
      >
      </div>
      <div class="relative mx-auto max-w-xl text-center">
        <p class="font-body text-sm font-semibold uppercase tracking-[0.2em] text-signal">
          Chegou pelo adesivo do carro?
        </p>
        <h1 class="balance mt-4 font-display text-5xl leading-[0.95] text-paper sm:text-6xl">
          BORA FAZER MÚSICA DE VERDADE
        </h1>
        <p class="mt-5 text-lg text-paper/70">
          Grava, masteriza, aprende ou compra loop pronto — escolhe o caminho aí embaixo.
        </p>
      </div>
    </section>

    <!-- FORK: os dois mundos -->
    <section class="px-6 pb-4">
      <div class="mx-auto grid max-w-4xl gap-4 sm:grid-cols-2">
        <a
          href="#em-music"
          class="reveal group rounded-2xl border border-ink-line bg-ink-raised p-6 transition-colors hover:border-signal"
        >
          <p class="font-display text-2xl text-signal">EM MUSIC PRODUÇÕES</p>
          <p class="mt-2 text-sm text-paper/60">
            Piseiro, arrocha, pagode, axé — o que toca na night.
          </p>
        </a>
        <a
          href="#prod-eder"
          class="reveal group rounded-2xl border border-ink-line bg-ink-raised p-6 transition-colors hover:border-gospel"
        >
          <p class="font-display text-2xl text-gospel">PROD. EDER MACHADO</p>
          <p class="mt-2 text-sm text-paper/60">
            Produção musical gospel, do jeito que edifica.
          </p>
        </a>
      </div>
    </section>

    <!-- OS 4 CAMINHOS -->
    <section id="em-music" class="px-6 py-14">
      <div class="mx-auto max-w-4xl">
        <h2 class="font-display text-3xl text-paper">O que a gente faz por você</h2>
        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          {paths.map((p) => (
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="reveal flex flex-col rounded-2xl border border-ink-line bg-ink-raised p-6 transition-transform hover:-translate-y-1"
            >
              <span class={`text-xs font-semibold uppercase tracking-[0.15em] text-${p.accent}`}>
                {p.cta}
              </span>
              <h3 class="mt-3 font-display text-xl text-paper">{p.title}</h3>
              <p class="mt-2 text-sm text-paper/60">{p.body}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="prod-eder" class="sr-only" aria-hidden="true"></section>

    <!-- CLIPES REAIS -->
    <section class="py-14">
      <div class="mx-auto max-w-4xl px-6">
        <h2 class="font-display text-3xl text-paper">Clipes e produções reais</h2>
        <p class="mt-2 text-sm text-paper/60">Direto dos nossos canais, sem imagem de banco.</p>
      </div>
      <div class="mt-8 flex snap-x snap-mandatory gap-4 overflow-x-auto px-6 pb-2 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        {videos.map((v) => (
          <a
            href={v.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative block w-64 shrink-0 snap-start overflow-hidden rounded-2xl border border-ink-line bg-ink-raised sm:w-72"
          >
            <span class="relative block aspect-video w-full overflow-hidden">
              <img
                src={v.thumb}
                alt={v.title}
                loading="lazy"
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
              />
              <span class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink/80 via-ink/0 to-ink/0" />
              <span class="absolute inset-0 flex items-center justify-center">
                <span class="flex h-11 w-11 items-center justify-center rounded-full bg-ink/70 ring-1 ring-paper/40">
                  <svg viewBox="0 0 24 24" class="ml-0.5 h-4 w-4 fill-paper"><path d="M8 5v14l11-7z" /></svg>
                </span>
              </span>
            </span>
            <p class="p-4 text-sm font-semibold text-paper">{v.title}</p>
            <span class="sr-only"> (abre no YouTube em nova aba)</span>
          </a>
        ))}
      </div>
    </section>

    <!-- RODAPÉ -->
    <footer class="border-t border-ink-line px-6 py-10">
      <div class="mx-auto flex max-w-4xl flex-col items-center gap-3 text-center">
        <p class="text-xs uppercase tracking-[0.2em] text-paper/40">Parte da</p>
        <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-paper/60">
          <span>Rede Loops Brasil</span>
          <a href="https://edtutoriais.com.br" class="hover:text-paper">ED Tutoriais</a>
          <a href="https://samplesbrasil.com" class="hover:text-paper">Samples Brasil</a>
          <span>EDTMusic</span>
        </div>
      </div>
    </footer>
  </main>

  <script>
    import { gsap } from 'gsap';

    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const items = document.querySelectorAll<HTMLElement>('.reveal');

    if (!prefersReduced && items.length) {
      gsap.set(items, { opacity: 0, y: 24 });
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              gsap.to(entry.target, { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' });
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.2 },
      );
      items.forEach((el) => io.observe(el));
    }
  </script>
</Base>
