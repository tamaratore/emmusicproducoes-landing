---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Pathways from '../components/Pathways.astro';
import Services from '../components/Services.astro';
import EdTutoriais from '../components/EdTutoriais.astro';
import Courses from '../components/Courses.astro';
import Process from '../components/Process.astro';
import Ecosystem from '../components/Ecosystem.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
import MobileActionBar from '../components/MobileActionBar.astro';
---

<Base>
  <Header />

  <main id="conteudo">
    <Hero />
    <Pathways />
    <Services />
    <EdTutoriais />
    <Courses />
    <Process />
    <Ecosystem />
    <FinalCTA />
  </main>

  <Footer />
  <MobileActionBar />

  <script>
    import { initNavigation } from '../scripts/navigation';
    import { initAnimations } from '../scripts/animations';

    initNavigation();
    initAnimations();
  </script>
</Base>
