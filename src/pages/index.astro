  apple: 'https://cloudinary-cdn.ffm.to/s--tXfmuRiI--/w_64,h_64,c_limit/f_webp/https%3A%2F%2Fassets.ffm.to%2Fimages%2Flogo%2Fmusic-service_applemusic_without_text.png',
